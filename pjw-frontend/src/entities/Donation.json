{
  "name": "Donation",
  "type": "object",
  "properties": {
    "donor_name": {
      "type": "string",
      "description": "Name of the donor (optional for anonymous)"
    },
    "amount": {
      "type": "number",
      "description": "Donation amount in USD"
    },
    "message": {
      "type": "string",
      "description": "Optional message from donor"
    },
    "is_anonymous": {
      "type": "boolean",
      "default": false
    },
    "donation_type": {
      "type": "string",
      "enum": [
        "one-time",
        "monthly",
        "merchandise"
      ],
      "default": "one-time"
    }
  },
  "required": [
    "amount"
  ]
}
