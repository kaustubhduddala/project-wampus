{
  "name": "Volunteer",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string",
      "description": "Volunteer's full name"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "phone": {
      "type": "string"
    },
    "total_hours": {
      "type": "number",
      "default": 0,
      "description": "Total volunteer hours contributed"
    },
    "total_deliveries": {
      "type": "number",
      "default": 0,
      "description": "Number of meal deliveries completed"
    },
    "availability": {
      "type": "string",
      "enum": [
        "weekdays",
        "weekends",
        "both",
        "flexible"
      ],
      "default": "flexible"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "pending"
      ],
      "default": "pending"
    }
  },
  "required": [
    "full_name",
    "email"
  ]
}
