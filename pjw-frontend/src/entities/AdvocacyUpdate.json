{
  "name": "AdvocacyUpdate",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Update title"
    },
    "content": {
      "type": "string",
      "description": "Detailed update content"
    },
    "bill_number": {
      "type": "string",
      "description": "Related bill/legislation number"
    },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "in-committee",
        "passed",
        "defeated",
        "signed"
      ],
      "description": "Current status of legislation"
    },
    "impact": {
      "type": "string",
      "enum": [
        "positive",
        "negative",
        "neutral"
      ],
      "description": "Impact on homelessness efforts"
    },
    "action_taken": {
      "type": "string",
      "description": "What PJW did in response"
    },
    "link_url": {
      "type": "string",
      "description": "Link to official legislation page"
    },
    "priority": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ],
      "default": "medium"
    }
  },
  "required": [
    "title",
    "content"
  ]
}
